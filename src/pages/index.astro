---
import { getCollection } from "astro:content";
import Layout from '../layouts/Layout.astro';

const googleReviewsUrl =
    "https://search.google.com/local/reviews?placeid=ChIJy4Bmq2wLHksRpfYxOGcyTa0";
const READ_MORE_THRESHOLD = 220;
/** Matches CSS `-webkit-line-clamp` on `.review-card-v1-text` */
const READ_MORE_MAX_LINES = 4;

function needsReadMore(text) {
    const trimmed = text.trim();
    if (!trimmed) return false;
    if (trimmed.length > READ_MORE_THRESHOLD) return true;
    return trimmed.split("\n").length > READ_MORE_MAX_LINES;
}

const reviewEntries = (await getCollection("reviews")).sort(
    (a, b) => a.data.order - b.data.order
);

const reviews = reviewEntries.map((entry) => ({
    ...entry.data,
    id: entry.id,
    text: entry.body.trim(),
}));

const serviceEntries = (await getCollection("services")).sort(
    (a, b) => a.data.order - b.data.order
);

const services = serviceEntries.map((entry) => ({
    ...entry.data,
    id: entry.id,
    description: entry.body.trim(),
}));

function getInitials(name) {
    if (!name) return "א";
    const parts = name.trim().split(/\s+/).filter(Boolean);
    if (!parts.length) return "א";
    if (parts.length === 1) return parts[0].charAt(0);
    return `${parts[0].charAt(0)}${parts[1].charAt(0)}`;
}
