---
// Panel Decap CMS — /admin (config en public/admin/config.yml)
import deployFile from "../../public/admin/deploy.json";

const isDevMode = import.meta.env.DEV;
const buildHookUrl = (
    import.meta.env.NETLIFY_BUILD_HOOK_URL ||
    deployFile.buildHookUrl ||
    ""
).trim();

const deployBtnDisabled = isDevMode || !buildHookUrl;

let deployStatusText = "";
let deployStatusError = false;
if (isDevMode) {
    deployStatusText = "זמין רק בפרודקשן";
    deployStatusError = true;
} else if (!buildHookUrl) {
    deployStatusText = "חסר Build Hook — ערכי /admin/deploy.json";
    deployStatusError = true;
}

const deployHint = isDevMode
    ? "מצב פיתוח — הכפתור מושבת כדי לא להפעיל בנייה ב-Netlify"
    : "לאחר שסיימת לפרסם את כל השינויים — לחצי כאן כדי לבנות ולהעלות את האתר";
---
<!doctype html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>ניהול תוכן — אורית גרושטיין</title>
    <link href="/admin/config.yml" type="text/yaml" rel="cms-config-url" />
    <link rel="stylesheet" href="/admin/admin.css" />
</head>
<body class="orit-deploy-bar-visible">
    <div
        id="orit-deploy-bar"
        role="region"
        aria-label="פרסום האתר"
        data-build-hook-url={buildHookUrl}
    >
        <p>{deployHint}</p>
        <button type="button" id="orit-deploy-btn" disabled={deployBtnDisabled}>
            פרסום לאתר
        </button>
        <span
            id="orit-deploy-status"
            class:list={["deploy-status", deployStatusError && "is-error"]}
            aria-live="polite"
        >
            {deployStatusText}
        </span>
    </div>

    <script is:inline src="https://unpkg.com/decap-cms@^3.8.3/dist/decap-cms.js"></script>
    <script is:inline>
        CMS.registerPreviewStyle(
            "body { direction: rtl; text-align: right; } p, h1, h2, h3, li { text-align: right; }",
            { raw: true }
        );
    </script>
    <script is:inline src="/admin/admin-deploy.js"></script>
</body>
</html>
