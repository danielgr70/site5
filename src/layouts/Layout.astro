    <!-- Google tag (gtag.js) lazy-loaded -->
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-S78VYCH8KJ');

        (function () {
            var loaded = false;
            function loadGtagScript() {
                if (loaded) return;
                loaded = true;
                var s = document.createElement('script');
                s.async = true;
                s.src = 'https://www.googletagmanager.com/gtag/js?id=G-S78VYCH8KJ';
                document.head.appendChild(s);
            }

            var opts = { once: true, passive: true };
            window.addEventListener('pointerdown', loadGtagScript, opts);
            window.addEventListener('keydown', loadGtagScript, opts);
            window.addEventListener('scroll', loadGtagScript, opts);
            window.setTimeout(loadGtagScript, 2500);
        })();
    </script>

    <meta charset="UTF-8" />
