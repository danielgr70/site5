# Copiá a .env solo para desarrollo local (npm run dev).
# En producción: TODO va en Cloudflare Pages → Settings → Variables and secrets (Production).
# No usamos wrangler.toml — el dashboard es la única fuente de verdad para env vars.

# --- Cloudflare Pages → Settings → Builds ---
# Build command:     npm run build
# Output directory:  dist

# --- Variables (texto) ---
# PUBLIC_KEYSTATIC_STORAGE=github
# PUBLIC_KEYSTATIC_GITHUB_REPO=danielgr70/site5

# --- Secrets (Encrypt en Cloudflare) ---
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=
# PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
# PUBLISH_API_TOKEN=              # openssl rand -hex 32
# CLOUDFLARE_DEPLOY_HOOK_URL=     # Settings → Deploy hooks → Create hook

# Después de agregar/cambiar variables: Deployments → Retry deployment.
# Las PUBLIC_* se incrustan en el build; hace falta redeploy.

# Publicación bajo demanda: desactivar "Automatic deployments" en main
# (Settings → Builds). Save en Keystatic → commit sin build; botón "פרסום לאתר" → hook.
